<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" prefHeight="800.0" prefWidth="1370.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.PatientAppointmentFormController">
   <children>
      <BorderPane layoutX="7.0" layoutY="14.0" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <Pane prefHeight="80.0" prefWidth="1370.0" BorderPane.alignment="CENTER">
               <children>
                  <Text layoutX="554.0" layoutY="49.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Appointment Schedule">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Text>
               </children></Pane>
         </top>
         <center>
            <Pane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <HBox prefHeight="723.0" prefWidth="1370.0" spacing="20">
                     <children>
                        <Pane prefHeight="723.0" prefWidth="1377.0">
                           <children>
                              <VBox prefHeight="728.0" prefWidth="1370.0">
                                 <children>
                                    <Text text="Patient ID">
                                       <VBox.margin>
                                          <Insets bottom="5.0" left="10.0" right="10.0" top="20.0" />
                                       </VBox.margin>
                                    </Text>
                                    <TextField fx:id="txtPatientId" prefHeight="35.0" prefWidth="534.0" promptText="e.g., P123">
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="10.0" right="10.0" />
                                       </VBox.margin>
                                    </TextField>

                                    <Text text="Doctor ID">
                                       <VBox.margin>
                                          <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                    </Text>
                                    <TextField fx:id="txtDoctorId" prefHeight="35.0" prefWidth="534.0" promptText="e.g., D123">
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="10.0" right="10.0" />
                                       </VBox.margin>
                                    </TextField>

                                    <Text text="Date">
                                       <VBox.margin>
                                          <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                    </Text>
                                    <DatePicker fx:id="dpDate" prefHeight="35.0" prefWidth="200.0">
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="10.0" right="10.0" />
                                       </VBox.margin>
                                    </DatePicker>

                                    <Text text="Time (HH:mm)">
                                       <VBox.margin>
                                          <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                    </Text>
                                    <TextField fx:id="txtTime" prefHeight="35.0" prefWidth="200.0" promptText="14:30">
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="10.0" right="10.0" />
                                       </VBox.margin>
                                    </TextField>

                                    <Text text="Description">
                                       <VBox.margin>
                                          <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                    </Text>
                                    <TextArea fx:id="txtDescription" prefHeight="120.0" prefWidth="534.0" promptText="Reason or notes...">
                                       <VBox.margin>
                                          <Insets bottom="10.0" left="10.0" right="10.0" />
                                       </VBox.margin>
                                    </TextArea>

                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                       <children>
                                          <Button fx:id="btnSave" onAction="#onSaveAppointment" stylesheets="@../css/dashboard.css" text="Save Appointment" />
                                          <Button onAction="#onClear" text="Clear" />
                                       </children>
                                       <VBox.margin>
                                          <Insets left="10.0" top="10.0" />
                                       </VBox.margin>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </Pane>
                     </children>
                  </HBox>
               </children></Pane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
