<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" pickOnBounds="false" prefHeight="800.0" prefWidth="1370.0" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.PharmacistFormController">

    <!-- Main Container -->
    <VBox fx:id="mainContainer" prefHeight="800.0" prefWidth="1370.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0">

        <!-- Top Header -->
        <HBox prefHeight="58.0" prefWidth="1370.0" styleClass="header" VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Text styleClass="header-title" text="GLOBE MED" />
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <Button styleClass="logout-button" text="Logout" />
            </HBox>
        </HBox>


        <!-- Main Content Area -->
        <HBox styleClass="content-container" VBox.vgrow="ALWAYS">
            <!-- Left Sidebar -->
            <VBox styleClass="sidebar" HBox.hgrow="NEVER">
                <!-- Sidebar Header -->
                <VBox alignment="CENTER" styleClass="sidebar-header">
                    <Circle radius="40" styleClass="user-avatar">
                        <VBox.margin>
                            <Insets top="20.0" />
                        </VBox.margin></Circle>
                </VBox>

                <!-- Navigation Menu -->
                <VBox styleClass="menu-container" VBox.vgrow="ALWAYS">
                    <Button prefWidth="220.0" style="-fx-text-fill: white;" styleClass="menu-button" text="Dashboard">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/dashboard.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button prefWidth="218.0" styleClass="menu-button" text="Patients">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/patient.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button prefWidth="233.0" styleClass="menu-button" text="Doctors">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/doctor.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button prefWidth="226.0" styleClass="menu-button" text="Nurses">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/nurse.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button prefWidth="226.0" styleClass="menu-button" text="Pharmacists">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/pharmacy.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>

            <!-- Main Content -->
            <VBox spacing="20" styleClass="content" HBox.hgrow="ALWAYS">
                <!-- Page Header -->
                <HBox alignment="CENTER_LEFT" style="-fx-spacing: 15;">
                    <Text styleClass="page-title" text="Pharmacists" />
                    <Text styleClass="page-subtitle" text="/ Management" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Pharmacist Form -->
                <GridPane hgap="15" style="-fx-padding: 20; -fx-background-color: #f5f7fa; -fx-background-radius: 10;" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" maxWidth="400" minWidth="300" prefWidth="350" />
                        <ColumnConstraints hgrow="ALWAYS" maxWidth="400" minWidth="300" prefWidth="350" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="NEVER" />
                        <RowConstraints vgrow="NEVER" />
                        <RowConstraints vgrow="NEVER" />
                    </rowConstraints>

                    <!-- Name -->
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox spacing="5">
                            <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Full Name" />
                            <Text style="-fx-fill: #e74c3c; -fx-font-size: 14; -fx-font-weight: bold;" text="*" />
                        </HBox>
                        <TextField fx:id="txtName" prefHeight="84.0" prefWidth="400.0" promptText="Enter full name" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10; -fx-font-size: 14;" />
                    </VBox>

                    <!-- Contact Number -->
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <HBox spacing="5">
                            <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Contact Number" />
                            <Text style="-fx-fill: #e74c3c; -fx-font-size: 14; -fx-font-weight: bold;" text="*" />
                        </HBox>
                        <TextField fx:id="txtContact" prefHeight="62.0" prefWidth="400.0" promptText="Enter contact number" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10; -fx-font-size: 14;" />
                    </VBox>

                    <!-- Email -->
                    <VBox GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                        <HBox prefHeight="72.0" prefWidth="815.0" spacing="5">
                            <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Email" />
                            <Text style="-fx-fill: #e74c3c; -fx-font-size: 14; -fx-font-weight: bold;" text="*" />
                        </HBox>
                        <TextField fx:id="txtEmail" promptText="Enter email address" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10; -fx-font-size: 14;" />
                    </VBox>

                    <!-- Action Buttons -->
                    <HBox alignment="CENTER_RIGHT" spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Button onAction="#OnClearFields" style="-fx-pref-width: 120; -fx-pref-height: 40; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-size: 14;" text="Clear" />
                        <Button fx:id="btnSave" onAction="#OnSavePharmacistAction" style="-fx-pref-width: 150; -fx-pref-height: 40; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-size: 14; -fx-font-weight: bold;" text="Save Pharmacist" />
                    </HBox>
                </GridPane>

                <!-- Pharmacists Table -->
                <VBox prefHeight="544.0" prefWidth="1090.0" style="-fx-padding: 20 0 0 0;" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" style="-fx-spacing: 15; -fx-padding: 0 0 15 0;">
                        <Text style="-fx-fill: #2c3e50; -fx-font-size: 18; -fx-font-weight: bold;" text="Pharmacist List" />
                        <Region prefHeight="70.0" prefWidth="712.0" HBox.hgrow="ALWAYS" />
                        <TextField prefHeight="35.0" promptText="Search pharmacists..." style="-fx-pref-height: 35; -fx-pref-width: 250; -fx-background-radius: 5; -fx-border-radius: 5; -fx-padding: 0 10;" />
                    </HBox>

                    <TableView fx:id="tblPharmacists" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ecf0f1;">
                        <columns>
                            <TableColumn fx:id="colName" prefWidth="300" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 10;" text="Name" />
                            <TableColumn fx:id="colContact" prefWidth="200" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 10;" text="Contact Number" />
                            <TableColumn fx:id="colEmail" prefWidth="350" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 10;" text="Email" />
                            <TableColumn fx:id="colActions" editable="false" prefWidth="150" style="-fx-alignment: CENTER;" text="Actions" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <!-- Pagination -->
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 15 0 0 0;">
                        <Button style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-pref-width: 80;" text="Previous" />
                        <HBox style="-fx-spacing: 5; -fx-padding: 0 15;">
                            <Button style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-pref-width: 35; -fx-pref-height: 35;" text="1" />
                            <Button style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-pref-width: 35; -fx-pref-height: 35;" text="2" />
                            <Button style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-pref-width: 35; -fx-pref-height: 35;" text="3" />
                            <Text style="-fx-fill: #7f8c8d; -fx-font-size: 14;" text="..." />
                            <Button style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-pref-width: 35; -fx-pref-height: 35;" text="10" />
                        </HBox>
                        <Button style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-pref-width: 80;" text="Next" />
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>

    <!-- Status Bar (Optional) -->
    <HBox prefWidth="1370.0" styleClass="status-bar" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0">
        <Text styleClass="status-text" text="Ready" />
    </HBox>
</AnchorPane>
