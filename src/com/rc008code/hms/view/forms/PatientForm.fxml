<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.PatientFormController">
   <children>
      <Text layoutX="40.0" layoutY="49.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Patient Managment">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Text>
      <TableView fx:id="tblePatients" layoutX="106.0" layoutY="284.0" prefHeight="469.0" prefWidth="989.0">
        <columns>
          <TableColumn fx:id="columnName" prefWidth="167.0" text="Name" />
          <TableColumn fx:id="columnAddress" prefWidth="180.0" text="Address" />
            <TableColumn fx:id="columnAge" prefWidth="117.0" text="Age" />
            <TableColumn fx:id="columnGender" prefWidth="78.0" text="Gender" />
            <TableColumn fx:id="columnContactNo" prefWidth="126.0" text="Contact Number" />
            <TableColumn fx:id="columnEmail" prefWidth="167.0" text="Email" />
            <TableColumn fx:id="columnOptions" prefWidth="153.0" text="Options" />
        </columns>
      </TableView>
      <TextField fx:id="txtName" layoutX="145.0" layoutY="95.0" prefHeight="26.0" prefWidth="279.0" promptText="Patient Name" />
      <TextField fx:id="txtAddress" layoutX="434.0" layoutY="95.0" prefHeight="26.0" prefWidth="279.0" promptText="Address" />
      <TextField fx:id="txtAge" layoutX="725.0" layoutY="95.0" prefHeight="26.0" prefWidth="115.0" promptText="Age" />
      <TextField fx:id="txtContactNo" layoutX="145.0" layoutY="135.0" prefHeight="26.0" prefWidth="279.0" promptText="Contact No" />
      <TextField fx:id="txtEmail" layoutX="434.0" layoutY="135.0" prefHeight="26.0" prefWidth="408.0" promptText="Email" />
      <RadioButton fx:id="rbtnMale" layoutX="863.0" layoutY="99.0" mnemonicParsing="false" selected="true" text="Male">
         <toggleGroup>
            <ToggleGroup fx:id="genderGrop" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="rbtnFemale" layoutX="944.0" layoutY="99.0" mnemonicParsing="false" text="Female" toggleGroup="$genderGrop" />
      <TextField fx:id="txtSearchPatients" layoutX="106.0" layoutY="237.0" prefHeight="26.0" prefWidth="989.0" promptText="Search Patients" />
      <Button layoutX="146.0" layoutY="178.0" mnemonicParsing="false" onAction="#onCreateAction" text="Save Patient" />
      <Button layoutX="989.0" layoutY="19.0" mnemonicParsing="false" onAction="#onBackToHomeAction" text="Back To Home" />
   </children>
</AnchorPane>
