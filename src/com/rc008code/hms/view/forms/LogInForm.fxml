<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #f5f8fd;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.LogInFormController">
    
    <!-- Main Container -->
    <VBox alignment="CENTER" prefHeight="450" prefWidth="400" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="200.0" AnchorPane.topAnchor="25.0">
        
        <!-- Header -->
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 40 0 30 0;">
            <Text style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #2c3e50;" text="Welcome Back" />
            <Text style="-fx-font-size: 14px; -fx-fill: #7f8c8d;" text="Please sign in to continue" />
        </VBox>
        
        <!-- Form -->
        <VBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 50 0 50; -fx-pref-width: 300;">
            <!-- Username Field -->
            <VBox spacing="5">
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: bold;" text="USERNAME" />
                <TextField fx:id="txtUserName" promptText="Enter your username" style="-fx-pref-height: 40; -fx-background-radius: 5;" styleClass="text-field" />
            </VBox>
            
            <!-- Password Field -->
            <VBox spacing="5">
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: bold;" text="PASSWORD" />
                <PasswordField fx:id="txtPassword" promptText="Enter your password" style="-fx-pref-height: 40; -fx-background-radius: 5;" styleClass="password-field" />
            </VBox>
            
            <!-- Remember Me & Forgot Password -->
            <HBox alignment="CENTER_RIGHT" prefWidth="300.0" style="-fx-padding: 5 0 20 0;">
                <Button style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-padding: 0; -fx-cursor: hand; -fx-font-size: 12px;" text="Forgot Password?" />
            </HBox>
            
            <!-- Login Button -->
            <Button onAction="#onLogInAction" style="-fx-pref-width: 300; -fx-pref-height: 45; -fx-background-radius: 5; -fx-font-size: 14px; -fx-font-weight: bold;" styleClass="login-button" text="SIGN IN">
            <VBox.margin>
               <Insets bottom="20.0" />
            </VBox.margin></Button>
        </VBox>
    </VBox>
</AnchorPane>
