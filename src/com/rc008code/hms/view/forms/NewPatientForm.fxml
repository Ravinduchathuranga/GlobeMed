<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" pickOnBounds="false" prefHeight="800.0" prefWidth="1370.0" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.NewPatientFormController">
    <BorderPane prefHeight="800.0" prefWidth="1370.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <top>

            <!-- Top Header -->
            <HBox prefHeight="58.0" prefWidth="1370.0" styleClass="header" BorderPane.alignment="CENTER">
                <Button mnemonicParsing="false" onAction="#OnBackToHome" styleClass="logout-button" text="Home">
                    <font>
                        <Font name="System Bold" size="19.0" />
                    </font>
                </Button>
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Text styleClass="header-title" text="GLOBE MED">
                        <HBox.margin>
                            <Insets left="30.0" />
                        </HBox.margin>
                    </Text>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Button styleClass="logout-button" text="Logout" />
                </HBox>
            </HBox>
        </top>
        <center>
            <Pane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                <children>
                    <Pane layoutX="14.0" layoutY="14.0" prefHeight="177.0" prefWidth="1339.0" styleClass="stats-card" stylesheets="@../css/dashboard.css">
                  <children>
                     <VBox layoutX="30.0" layoutY="20.0" prefHeight="65.0" prefWidth="254.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Full Name" />
                           <TextField fx:id="txtName" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10;" />
                        </children>
                     </VBox>
                     <VBox layoutX="297.0" layoutY="20.0" prefHeight="65.0" prefWidth="183.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Age" />
                           <TextField fx:id="txtAge" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10;" />
                        </children>
                     </VBox>
                     <VBox layoutX="508.0" layoutY="20.0" prefHeight="80.0" prefWidth="173.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Gender" />
                           <HBox prefHeight="18.0" prefWidth="105.0" spacing="15" style="-fx-alignment: center-left;">
                              <children>
                                 <RadioButton fx:id="rbtnMale" selected="true" style="-fx-text-fill: #2c3e50;" text="Male">
                                    <toggleGroup>
                                       <ToggleGroup fx:id="genderGroup" />
                                    </toggleGroup>
                                 </RadioButton>
                                 <RadioButton fx:id="rbtnFemale" style="-fx-text-fill: #2c3e50;" text="Female" toggleGroup="$genderGroup" />
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                     <VBox layoutX="697.0" layoutY="20.0" prefHeight="65.0" prefWidth="326.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Contact Number" />
                           <TextField fx:id="txtContactNo" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10;" />
                        </children>
                     </VBox>
                     <VBox layoutX="1037.0" layoutY="20.0" prefHeight="65.0" prefWidth="288.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Address" />
                           <TextField fx:id="txtAddress" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10;" />
                        </children>
                     </VBox>
                     <VBox layoutX="30.0" layoutY="99.0" prefHeight="65.0" prefWidth="259.0" spacing="5">
                        <children>
                           <Text style="-fx-fill: #2c3e50; -fx-font-size: 14; -fx-font-weight: bold;" text="Email" />
                           <TextField fx:id="txtEmail" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7; -fx-padding: 0 10;" />
                        </children>
                     </VBox>
                     <HBox alignment="CENTER_RIGHT" layoutX="992.0" layoutY="131.0" spacing="15" />
                     <Button fx:id="btnSave" layoutX="304.0" layoutY="124.0" onAction="#OnSavePatientAction" style="-fx-pref-width: 120; -fx-pref-height: 40; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Save Patient" />
                     <Button layoutX="448.0" layoutY="124.0" onAction="#OnClearFields" style="-fx-pref-width: 120; -fx-pref-height: 40; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Clear" />
                  </children>
                    </Pane>
                    <Pane layoutX="14.0" layoutY="199.0" prefHeight="515.0" prefWidth="1338.0" styleClass="stats-card" stylesheets="@../css/dashboard.css">
                        <children>
                     <TableView fx:id="tblPatients" layoutX="15.0" layoutY="71.0" prefHeight="435.0" prefWidth="1309.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ecf0f1;">
                        <columns>
                           <TableColumn fx:id="colPatientId" maxWidth="120" minWidth="120" prefWidth="120" resizable="false" sortable="false" text="Patient ID" />
                           <TableColumn fx:id="colName" maxWidth="200" minWidth="150" prefWidth="180" resizable="true" sortable="true" text="Full Name" />
                           <TableColumn fx:id="colAge" maxWidth="80" minWidth="80" prefWidth="80" resizable="false" sortable="true" text="Age" />
                           <TableColumn fx:id="colGender" maxWidth="100" minWidth="80" prefWidth="98.0" resizable="false" sortable="true" text="Gender" />
                           <TableColumn fx:id="colAddress" maxWidth="250" minWidth="190.0" prefWidth="190.0" resizable="true" sortable="true" text="Address" />
                           <TableColumn fx:id="colContact" maxWidth="198.0" minWidth="120" prefWidth="148.0" resizable="true" sortable="true" text="Contact No" />
                           <TableColumn fx:id="colEmail" maxWidth="287.0" minWidth="200" prefWidth="205.0" resizable="true" sortable="true" text="Email" />
                           <TableColumn fx:id="colAction" maxWidth="250.0" minWidth="120" prefWidth="250.0" resizable="false" sortable="false" text="Action" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>
                     <Text layoutX="21.0" layoutY="47.0" style="-fx-fill: #2c3e50; -fx-font-size: 18; -fx-font-weight: bold;" text="Patient List" />
                     <TextField fx:id="txtSearchPatients" layoutX="1074.0" layoutY="27.0" promptText="Search patients..." style="-fx-pref-height: 35; -fx-pref-width: 250; -fx-background-radius: 5; -fx-border-radius: 5; -fx-padding: 0 10;" />
                        </children>
                    </Pane>
                </children>
            </Pane>
        </center>
    </BorderPane>
</AnchorPane>
