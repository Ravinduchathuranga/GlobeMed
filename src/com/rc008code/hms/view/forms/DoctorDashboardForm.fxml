<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="context" maxHeight="800.0" maxWidth="1370.0" minHeight="800.0" minWidth="1370.0" pickOnBounds="false" prefHeight="800.0" prefWidth="1370.0" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rc008code.hms.controller.DoctorDashboardFormController">

    <!-- Main Container -->
    <VBox fx:id="mainContainer" prefHeight="800.0" prefWidth="1370.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0">

        <!-- Top Header -->
        <HBox prefHeight="58.0" prefWidth="1370.0" styleClass="header" VBox.vgrow="NEVER">
            <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Text styleClass="header-title" text="GLOBE MED" />
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <Button onAction="#OnLogOutAction" styleClass="logout-button" text="Logout" />
            </HBox>
        </HBox>


        <!-- Main Content Area -->
        <HBox styleClass="content-container" VBox.vgrow="ALWAYS">
            <!-- Left Sidebar -->
            <VBox styleClass="sidebar" HBox.hgrow="NEVER">
                <!-- Sidebar Header -->
                <VBox alignment="CENTER" styleClass="sidebar-header">
                    <Circle radius="40" styleClass="user-avatar">
                        <VBox.margin>
                            <Insets top="20.0" />
                        </VBox.margin></Circle>
                </VBox>

                <!-- Navigation Menu -->
                <VBox styleClass="menu-container" VBox.vgrow="ALWAYS">
                    <Button prefWidth="220.0" style="-fx-text-fill: white;" styleClass="menu-button" text="Dashboard">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true" smooth="true">
                                <image>
                                    <!-- Image URL will be added later -->
                                    <!-- <Image url="@../../../../resources/icons/dashboard.png" /> -->
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>
         <BorderPane prefHeight="742.0" prefWidth="1165.0">
            <top>
               <Pane prefHeight="90.0" prefWidth="1150.0" BorderPane.alignment="CENTER">
                  <children>
                     <Text layoutX="14.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Doctor Dashboard">
                        <font>
                           <Font name="System Bold" size="26.0" />
                        </font>
                     </Text>
                     <Text layoutX="14.0" layoutY="77.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Paged Patients for doctor" />
                  </children>
               </Pane>
            </top>
            <bottom>
               <Pane prefHeight="57.0" prefWidth="1150.0" BorderPane.alignment="CENTER" />
            </bottom>
            <center>
               <TableView fx:id="tblPatients" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                 <columns>
                   <TableColumn fx:id="colPatientId" prefWidth="89.0" text="Patient Id" />
                   <TableColumn fx:id="colPatientName" prefWidth="121.0" text="Full Name" />
                     <TableColumn fx:id="colPatientAge" prefWidth="68.0" text="Age" />
                     <TableColumn fx:id="colPatientGender" prefWidth="99.0" text="Gender" />
                     <TableColumn fx:id="colPatientAddress" prefWidth="184.0" text="Address" />
                     <TableColumn fx:id="colPatientContactNo" prefWidth="149.0" text="Contact No" />
                     <TableColumn fx:id="colPatientEmail" prefWidth="250.0" text="Email" />
                     <TableColumn fx:id="colPatientAction" minWidth="0.0" prefWidth="189.0" text="Action" />
                 </columns>
               </TableView>
            </center>
         </BorderPane>
        </HBox>
    </VBox>

    <!-- Status Bar (Optional) -->
    <HBox prefWidth="1370.0" styleClass="status-bar" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0">
        <Text styleClass="status-text" text="Ready" />
    </HBox>
</AnchorPane>
