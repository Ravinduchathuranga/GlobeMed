                     <TableView fx:id="tblPharmacists" layoutX="11.0" layoutY="61.0" prefHeight="417.0" prefWidth="1316.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ecf0f1;">
